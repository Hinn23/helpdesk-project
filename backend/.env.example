DATABASE_URL=sqlite:///./helpdesk.db
SECRET_KEY=change-me-in-production
REFRESH_SECRET_KEY=change-me-in-production
ALLOWED_EMAIL_DOMAINS=gmail.com,mail.ru,yandex.ru
DISABLE_RATE_LIMIT=true
FRONTEND_URL=http://localhost:5173

# SMTP для отправки писем (регистрация и т.д.)
# По умолчанию — MailHog (локаленый SMTP-сервер)
# Чтобы использовать реальную почту — раскомментируй и заполни:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM=your_email@gmail.com
